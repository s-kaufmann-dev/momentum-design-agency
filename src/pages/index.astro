---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import About from '../components/sections/About.astro';
import Talents from '../components/sections/Talents.astro';
import Cursor from '../components/Cursor.astro';
import CursorTrails from '../components/CursorTrails.astro';
import AudioEngine from '../components/AudioEngine.astro';
import WebGLDistortion from '../components/WebGLDistortion.astro';

// Momentum Design - High-End Digital Agency Website
---

<Layout title="Momentum Design | Avant-garde Branding & Kinetic Digital Experiences">
	<main id="main-content" class="relative">
		<Hero />
		<About />
		<Portfolio />
		<Talents />
        
        <!-- Footer / Contact -->
        <footer class="bg-black py-32 text-center border-t border-white/5">
            <div class="container mx-auto px-6">
                <h2 class="text-[12vw] font-black tracking-tighter uppercase leading-none mb-8 hover:text-accent transition-colors duration-500 cursor-pointer" data-magnetic>
                    Let's Talk
                </h2>
                <div class="flex justify-between items-center text-[10px] uppercase tracking-widest text-white/30 px-4">
                    <span>© 2026 Momentum Design</span>
                    <div class="flex gap-12">
                        <a href="#" class="hover:text-white" data-magnetic>Instagram</a>
                        <a href="#" class="hover:text-white" data-magnetic>Behance</a>
                        <a href="#" class="hover:text-white" data-magnetic>Contact</a>
                    </div>
                </div>
            </div>
        </footer>
	</main>
    
    <!-- Global Layers -->
    <Cursor />
    <CursorTrails />
    <AudioEngine />
    <WebGLDistortion />
</Layout>

<style>
	main {
		background-color: var(--bg);
		color: var(--fg);
	}
</style>
