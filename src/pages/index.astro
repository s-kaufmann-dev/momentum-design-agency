---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Services from '../components/sections/Services.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import Process from '../components/sections/Process.astro';
import Talents from '../components/sections/Talents.astro';
import Cursor from '../components/Cursor.astro';
import CursorTrails from '../components/CursorTrails.astro';
import AudioEngine from '../components/AudioEngine.astro';
import WebGLDistortion from '../components/WebGLDistortion.astro';
---

<Layout title="Momentum Design | Premium Webagentur aus Düsseldorf" description="Momentum Design ist eine Webagentur aus Düsseldorf. Wir entwickeln kinetic Webdesign, Branding & immersive 3D-Erlebnisse.">
  <main id="main-content" class="relative overflow-x-hidden">
    <Hero />
    <About />
    <Services />
    <Portfolio />
    <Process />
    <Talents />

    <!-- Contact + Footer -->
    <footer id="contact" class="bg-black py-32 relative overflow-hidden border-t border-white/5">
      <!-- Big scroll typography -->
      <div class="overflow-hidden absolute top-0 left-0 w-full pointer-events-none">
        <p id="footer-bg" class="text-[30vw] font-black text-white/[0.02] uppercase leading-none whitespace-nowrap select-none">KONTAKT KONTAKT KONTAKT</p>
      </div>

      <div class="container mx-auto px-6 relative z-10 text-center">
        <p class="text-accent text-[9px] uppercase tracking-[0.5em] mb-8">06 / Kontakt</p>
        
        <h2
          class="text-[clamp(4rem,14vw,16rem)] font-black tracking-tighter uppercase leading-none mb-8 hover:text-accent transition-colors duration-700 cursor-pointer"
          data-magnetic
          data-magnetic-label="Schreib uns"
        >
          Lass uns reden
        </h2>
        
        <p class="text-white/30 text-sm uppercase tracking-widest mb-16 max-w-lg mx-auto">
          Du hast ein Projekt? Wir haben die Energie.<br/>
          Gemeinsam erschaffen wir etwas Außergewöhnliches.
        </p>

        <a
          href="mailto:hello@momentum-design.de"
          class="inline-block text-white/60 hover:text-accent transition-colors duration-300 text-sm uppercase tracking-widest group"
          data-magnetic
        >
          hello@momentum-design.de
          <span class="block w-0 group-hover:w-full h-px bg-accent transition-all duration-500 mt-1"></span>
        </a>
        
        <div class="mt-32 flex justify-between items-center text-[9px] uppercase tracking-widest text-white/20">
          <span>© 2026 Momentum Design GmbH</span>
          <div class="flex gap-10">
            <a href="#" class="hover:text-white transition-colors duration-300" data-magnetic>Instagram</a>
            <a href="#" class="hover:text-white transition-colors duration-300" data-magnetic>LinkedIn</a>
            <a href="#" class="hover:text-white transition-colors duration-300" data-magnetic>Behance</a>
            <a href="#" class="hover:text-white transition-colors duration-300" data-magnetic>Impressum</a>
          </div>
        </div>
      </div>
    </footer>
  </main>

  <!-- Global interactive layers -->
  <Cursor />
  <CursorTrails />
  <AudioEngine />
  <WebGLDistortion />
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Footer scroll typography
  const footerBg = document.getElementById('footer-bg');
  if (footerBg) {
    gsap.fromTo(footerBg,
      { x: '0%' },
      { x: '-30%', ease: 'none', scrollTrigger: { trigger: '#contact', start: 'top bottom', end: 'bottom bottom', scrub: 1 } }
    );
  }
</script>

<style>
  main { background-color: var(--bg); color: var(--fg); }
  ::selection { background: rgba(255,77,0,0.3); }
  html { cursor: none; }
</style>
