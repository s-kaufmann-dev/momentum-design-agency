<!-- Custom Cursor - pointer-events MUST be none so it never blocks clicks -->
<div id="cursor-outer" class="fixed pointer-events-none z-[2147483645] opacity-0" style="pointer-events:none;"></div>
<div id="cursor-dot" class="fixed pointer-events-none z-[2147483646] opacity-0" style="pointer-events:none;"></div>
<div id="cursor-label" class="fixed pointer-events-none z-[2147483647] opacity-0 text-[9px] uppercase tracking-widest text-white/80 whitespace-nowrap" style="pointer-events:none;"></div>

<script>
  import gsap from 'gsap';
  import { engine } from '../lib/engine';

  const outer = document.getElementById('cursor-outer');
  const dot = document.getElementById('cursor-dot');
  const label = document.getElementById('cursor-label');

  if (!outer || !dot || !label) { /* skip SSR */ }
  else {
    // ─── Style the cursor rings ─────────────────────────────────────
    Object.assign(outer.style, {
      width: '40px', height: '40px',
      borderRadius: '50%',
      border: '1px solid rgba(255,77,0,0.6)',
      marginLeft: '-20px', marginTop: '-20px',
      transformOrigin: 'center center',
      mixBlendMode: 'difference',
      willChange: 'transform',
      transition: 'opacity 0.3s'
    });
    Object.assign(dot.style, {
      width: '6px', height: '6px',
      borderRadius: '50%',
      background: '#ff4d00',
      marginLeft: '-3px', marginTop: '-3px',
      transformOrigin: 'center center',
      willChange: 'transform',
      transition: 'opacity 0.3s'
    });

    // ─── Show cursor on first move ──────────────────────────────────
    let hasMoved = false;
    window.addEventListener('mousemove', () => {
      if (!hasMoved) {
        hasMoved = true;
        gsap.to([outer, dot], { opacity: 1, duration: 0.5 });
      }
    });

    // ─── GSAP driven position + velocity stretch ─────────────────────
    engine.subscribe(() => {
      const mx = engine.mouse.lx;
      const my = engine.mouse.ly;

      // Velocity-based stretching (squash & stretch)
      const speed = Math.sqrt(engine.mouse.vx ** 2 + engine.mouse.vy ** 2);
      const stretch = 1 + Math.min(speed * 0.12, 1.2);
      const angle = Math.atan2(engine.mouse.vy, engine.mouse.vx) * (180 / Math.PI);

      gsap.set(outer, {
        x: mx, y: my,
        scaleX: stretch,
        scaleY: 1 / stretch,
        rotation: angle,
      });
      gsap.set(dot, { x: engine.mouse.x, y: engine.mouse.y });
      gsap.set(label, { x: engine.mouse.x + 20, y: engine.mouse.y + 20 });
    });

    // ─── Magnetic Effect ───────────────────────────────────────────
    document.querySelectorAll('[data-magnetic]').forEach(el => {
      const element = el as HTMLElement;
      const magnetLabel = element.dataset.magneticLabel || '';

      element.addEventListener('mouseenter', () => {
        gsap.to(outer, { scale: 2.5, borderColor: 'rgba(255,77,0,1)', duration: 0.4 });
        if (magnetLabel) {
          label.textContent = magnetLabel;
          gsap.to(label, { opacity: 1, duration: 0.3 });
        }
      });

      element.addEventListener('mousemove', (e) => {
        const bounds = element.getBoundingClientRect();
        const relX = e.clientX - bounds.left - bounds.width / 2;
        const relY = e.clientY - bounds.top - bounds.height / 2;
        gsap.to(element, {
          x: relX * 0.35,
          y: relY * 0.35,
          duration: 0.6,
          ease: 'power3.out'
        });
      });

      element.addEventListener('mouseleave', () => {
        gsap.to(outer, { scale: 1, borderColor: 'rgba(255,77,0,0.6)', duration: 0.4 });
        gsap.to(element, { x: 0, y: 0, duration: 0.8, ease: 'elastic.out(1,0.5)' });
        gsap.to(label, { opacity: 0, duration: 0.2 });
        label.textContent = '';
      });
    });

    // ─── Cursor state changes ──────────────────────────────────────
    document.addEventListener('mousedown', () => {
      gsap.to(outer, { scale: 0.7, duration: 0.15 });
    });
    document.addEventListener('mouseup', () => {
      gsap.to(outer, { scale: 1, duration: 0.3, ease: 'elastic.out(1,0.5)' });
    });
  }
</script>
