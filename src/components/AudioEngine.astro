---
---

<!-- Audio Gateway Overlay - z-index must be HIGHEST of all layers -->
<div id="audio-overlay" class="fixed inset-0 bg-[#030303] flex flex-col items-center justify-center" style="z-index: 99999;">
  <!-- Animated background text -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-[0.03]">
    <div class="absolute top-1/4 left-0 text-[25vw] font-black uppercase whitespace-nowrap leading-none tracking-tighter animate-slide-left">MOMENTUM MOMENTUM MOMENTUM</div>
    <div class="absolute bottom-1/4 left-0 text-[25vw] font-black uppercase whitespace-nowrap leading-none tracking-tighter animate-slide-right">DESIGN DESIGN DESIGN DESIGN</div>
  </div>
  
  <div class="relative z-10 text-center">
    <p class="text-white/30 text-[10px] uppercase tracking-[0.4em] mb-12">Momentum Design Agentur / 2026</p>
    
    <!-- The button itself must have pointer-events: auto explicitly -->
    <button 
      id="unmute-btn" 
      style="position:relative; z-index: 100000; cursor: pointer; pointer-events: auto;"
      class="group overflow-hidden px-16 py-8 border border-white/20 hover:border-white/60 transition-colors duration-500"
    >
      <span class="relative z-10 text-white text-2xl font-light tracking-[0.3em] uppercase group-hover:tracking-[0.5em] transition-all duration-700">EINTRETEN</span>
      <div class="absolute inset-0 bg-white/5 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left pointer-events-none"></div>
    </button>
    
    <p class="text-white/25 mt-8 text-[9px] tracking-[0.3em] uppercase">Am besten mit Audio-Eindrücken erleben</p>
    
    <div class="mt-16 flex items-center justify-center gap-3">
      <div class="w-1 h-1 rounded-full bg-accent animate-ping"></div>
      <span class="text-white/20 text-[8px] uppercase tracking-widest">Ton wird aktiviert</span>
    </div>
  </div>
</div>

<script>
  import { Howl, Howler } from 'howler';
  import { engine } from '../lib/engine';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const overlay = document.getElementById('audio-overlay') as HTMLElement;
  const unmuteBtn = document.getElementById('unmute-btn') as HTMLButtonElement;

  // ─── Web Audio API context (created on user gesture) ────────────
  let audioCtx: AudioContext | null = null;
  let lowpassFilter: BiquadFilterNode | null = null;
  let pannerNode: StereoPannerNode | null = null;

  // ─── Howler sounds ───────────────────────────────────────────────
  let hoverSound: Howl | null = null;
  let clickSound: Howl | null = null;
  let ambientSound: Howl | null = null;

  function initAudio() {
    try {
      // Create AudioContext fresh on user click (required by browsers)
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();

      // Resume if suspended
      if (audioCtx.state === 'suspended') {
        audioCtx.resume();
      }

      // Build effects chain: panner → lowpass → destination
      pannerNode = audioCtx.createStereoPanner();
      lowpassFilter = audioCtx.createBiquadFilter();
      lowpassFilter.type = 'lowpass';
      lowpassFilter.frequency.value = 20000;
      lowpassFilter.Q.value = 0.8;

      pannerNode.connect(lowpassFilter);
      lowpassFilter.connect(audioCtx.destination);

      // Wire Howler into our chain
      Howler.ctx = audioCtx;
      try {
        Howler.masterGain.disconnect();
        Howler.masterGain.connect(pannerNode);
      } catch(e) {
        // If disconnect fails, just connect directly
        Howler.masterGain.connect(pannerNode);
      }

      // ─── Load sounds with fallback URLs ─────────────────────────
      // Using multiple src fallbacks for reliability
      hoverSound = new Howl({
        src: ['/audio/hover.mp3'],
        volume: 0.07,
        onloaderror: () => console.log('hover sound load error - silent fail')
      });

      clickSound = new Howl({
        src: ['/audio/click.mp3'],
        volume: 0.12,
        onloaderror: () => console.log('click sound load error - silent fail')
      });

      // Ambient: use a looping tone generated via Web Audio as fallback
      ambientSound = new Howl({
        src: ['/audio/ambient.mp3'],
        loop: true,
        volume: 0,
        onloaderror: () => {
          console.log('ambient mp3 failed, using oscillator fallback');
          startOscillatorAmbient();
        }
      });

      const playId = ambientSound.play();
      ambientSound.fade(0, 0.18, 3000);

      // ─── Spatial panning from mouse position ────────────────────
      engine.subscribe(() => {
        if (!pannerNode || !audioCtx || audioCtx.state !== 'running') return;
        const norm = (engine.mouse.lx / window.innerWidth) * 2 - 1;
        pannerNode.pan.setTargetAtTime(norm * 0.35, audioCtx.currentTime, 0.3);
      });

      // ─── Scroll-driven lowpass soundscape ───────────────────────
      ScrollTrigger.create({
        start: 0,
        end: 'max',
        onUpdate: (self) => {
          if (!lowpassFilter || !audioCtx || audioCtx.state !== 'running') return;
          const p = self.progress;
          const freq = p < 0.5
            ? 20000 - p * 2 * 15000
            : 5000 + (p - 0.5) * 2 * 15000;
          lowpassFilter.frequency.setTargetAtTime(Math.max(500, freq), audioCtx.currentTime, 0.4);
        }
      });

      // ─── UI sounds on interactions ───────────────────────────────
      window.addEventListener('mousedown', () => {
        if (engine.isAudioEnabled && clickSound) clickSound.play();
      });

      document.querySelectorAll('a, button, [data-magnetic]').forEach(el => {
        el.addEventListener('mouseenter', () => {
          if (engine.isAudioEnabled && hoverSound) hoverSound.play();
        });
      });

    } catch(err) {
      console.error('Audio init error:', err);
    }
  }

  // ─── Oscillator Ambient Fallback (no file needed) ─────────────────
  function startOscillatorAmbient() {
    if (!audioCtx) return;
    // Create a subtle drone using oscillators (pure Web Audio, no file)
    const createDroneOsc = (freq: number, gain: number) => {
      const osc = audioCtx!.createOscillator();
      const gainNode = audioCtx!.createGain();
      osc.type = 'sine';
      osc.frequency.value = freq;
      gainNode.gain.value = gain;
      osc.connect(gainNode);
      gainNode.connect(lowpassFilter || audioCtx!.destination);
      osc.start();
    };

    // Deep drone: 40Hz + 60Hz + 80Hz creates rich ambient texture
    createDroneOsc(40, 0.04);
    createDroneOsc(60, 0.02);
    createDroneOsc(80, 0.015);
    createDroneOsc(120, 0.008);
  }

  // ─── Button click handler ─────────────────────────────────────────
  if (unmuteBtn) {
    unmuteBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      engine.enableAudio();
      initAudio();

      gsap.to(overlay, {
        opacity: 0,
        duration: 1.2,
        ease: 'power4.inOut',
        onComplete: () => {
          overlay.style.display = 'none';
          overlay.style.pointerEvents = 'none';
        }
      });
    });
  }
</script>

<style>
  #audio-overlay {
    pointer-events: auto !important;
  }
  #unmute-btn {
    pointer-events: auto !important;
    cursor: pointer !important;
  }
  @keyframes slide-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes slide-right {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }
  .animate-slide-left { animation: slide-left 20s linear infinite; }
  .animate-slide-right { animation: slide-right 20s linear infinite; }
</style>
