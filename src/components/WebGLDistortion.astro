---
---
<canvas id="liquid-canvas" class="fixed top-0 left-0 w-full h-full pointer-events-none z-[-1]" aria-hidden="true"></canvas>

<script>
  import * as THREE from 'three';
  import { engine } from '../lib/engine';

  // Liquid Distortion Shader
  const vertexShader = `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `;

  const fragmentShader = `
    uniform sampler2D tDiffuse;
    uniform float uTime;
    uniform float uVelocity;
    uniform float uScroll;
    varying vec2 vUv;

    // Simple 2D Noise
    float noise(vec2 p) {
      return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453);
    }

    void main() {
      vec2 uv = vUv;
      
      // Liquid Ripple effect based on velocity and scroll
      float distortion = sin(uv.y * 10.0 + uTime * 2.0 + uScroll * 0.1) * (uVelocity * 0.005 + 0.01);
      uv.x += distortion;
      uv.y += distortion * 0.5;

      vec4 color = texture2D(tDiffuse, uv);
      gl_FragColor = color;
    }
  `;

  const canvas = document.getElementById('liquid-canvas') as HTMLCanvasElement;
  if (canvas) {
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(engine.viewport.pixelRatio);
    renderer.setSize(window.innerWidth, window.innerHeight);

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0.1, 10);
    camera.position.z = 1;

    // We'll map the DOM images to Three.js planes
    const images = document.querySelectorAll('[data-distort]') as NodeListOf<HTMLImageElement>;
    const items: Array<{ mesh: THREE.Mesh; el: HTMLImageElement; texture: THREE.Texture }> = [];

    const textureLoader = new THREE.TextureLoader();

    images.forEach(img => {
      const texture = textureLoader.load(img.src);
      const material = new THREE.ShaderMaterial({
        uniforms: {
          tDiffuse: { value: texture },
          uTime: { value: 0 },
          uVelocity: { value: 0 },
          uScroll: { value: 0 }
        },
        vertexShader,
        fragmentShader,
        transparent: true
      });

      const geometry = new THREE.PlaneGeometry(2, 2);
      const mesh = new THREE.Mesh(geometry, material);
      scene.add(mesh);
      items.push({ mesh, el: img, texture });
      
      // Hide the original image (it's being drawn by three.js)
      img.style.opacity = '0';
    });

    const updatePlanes = () => {
      items.forEach(item => {
        const bounds = item.el.getBoundingClientRect();
        
        // Map DOM bounds to Three.js Normalized Device Coordinates (-1 to 1)
        const w = (bounds.width / window.innerWidth) * 2;
        const h = (bounds.height / window.innerHeight) * 2;
        const x = (bounds.left / window.innerWidth) * 2 - 1 + w / 2;
        const y = -(bounds.top / window.innerHeight) * 2 + 1 - h / 2;

        item.mesh.scale.set(w / 2, h / 2, 1);
        item.mesh.position.set(x, y, 0);

        // Update uniforms
        const velocity = Math.sqrt(engine.mouse.vx ** 2 + engine.mouse.vy ** 2);
        (item.mesh.material as THREE.ShaderMaterial).uniforms.uTime.value += 0.01;
        (item.mesh.material as THREE.ShaderMaterial).uniforms.uVelocity.value = velocity;
        (item.mesh.material as THREE.ShaderMaterial).uniforms.uScroll.value = engine.scroll.current;
      });
    };

    engine.subscribe(() => {
      if (items.length === 0) return; // HUGE SAFARI CPU WIN: don't render a blank scene
      updatePlanes();
      renderer.render(scene, camera);
    });

    window.addEventListener('resize', () => {
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(engine.viewport.pixelRatio);
    });
  }
</script>
