---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Momentum Design — Premium Webagentur aus Düsseldorf. Webdesign, Branding & immersive digitale Erlebnisse." } = Astro.props;
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- Fonts: Outfit variable -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet" />
    <!-- Force dark theme always -->
    <style>
      html, body { background: #050505; }
    </style>
  </head>
  <body class="antialiased overflow-x-hidden">
    <slot />
    <canvas id="webgl" aria-hidden="true" style="pointer-events:none;"></canvas>
  </body>
</html>
